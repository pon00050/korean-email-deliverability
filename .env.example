# Phase 1 (CLI) — no API keys required.
# All checks use public DNS and HTTP endpoints.

# Future: paid blacklist APIs, KISA partner credentials, etc.
# KISA_API_KEY=

# ---------------------------------------------------------------------------
# Phase 2 (Hosted SaaS) — required for app.py
# ---------------------------------------------------------------------------

# PostgreSQL connection string (provided automatically by Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Resend API key (https://resend.com) — 3,000 free emails/month
RESEND_API_KEY=re_your_key_here

# Verified sender address configured in Resend
FROM_EMAIL=noreply@yourdomain.com

# Public base URL of the deployed app (used to build unsubscribe links)
BASE_URL=https://your-app.railway.app

# ---------------------------------------------------------------------------
# Phase 3 (Batch API) — optional
# ---------------------------------------------------------------------------

# API key required in X-API-Key header on POST /batch.
# Leave unset to disable auth (development / local testing).
BATCH_API_KEY=

# Set to any non-empty value to skip DB and scheduler init on startup.
# Enables /health → "ok" and /batch without a Postgres connection.
# /subscribe will fail — DB is required for that route.
SENDERFIT_SKIP_DB=
